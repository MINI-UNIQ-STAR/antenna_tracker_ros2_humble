<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="antenna_tracker">

  <!-- Properties -->
  <xacro:property name="base_height" value="0.1"/>
  <xacro:property name="base_radius" value="0.15"/>
  <xacro:property name="column_height" value="0.3"/>
  <xacro:property name="column_radius" value="0.04"/>
  <xacro:property name="arm_length" value="0.25"/>
  <xacro:property name="arm_width" value="0.06"/>
  <xacro:property name="arm_height" value="0.04"/>
  <xacro:property name="antenna_length" value="0.4"/>
  <xacro:property name="antenna_radius" value="0.15"/>

  <!-- Materials -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>

  <!-- Base Link (fixed to ground) -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.08"/>
    </inertial>
  </link>

  <!-- Azimuth Link (rotates around Z axis) -->
  <link name="azimuth_link">
    <visual>
      <geometry>
        <cylinder radius="${column_radius}" length="${column_height}"/>
      </geometry>
      <origin xyz="0 0 ${column_height/2}" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${column_radius}" length="${column_height}"/>
      </geometry>
      <origin xyz="0 0 ${column_height/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="azimuth_joint" type="revolute">
    <parent link="base_link"/>
    <child link="azimuth_link"/>
    <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-pi}" upper="${pi}" effort="10.0" velocity="3.14159"/>
  </joint>

  <!-- Elevation Link (rotates around Y axis) -->
  <link name="elevation_link">
    <visual>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_height}"/>
      </geometry>
      <origin xyz="${arm_length/2} 0 0" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_height}"/>
      </geometry>
      <origin xyz="${arm_length/2} 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="elevation_joint" type="revolute">
    <parent link="azimuth_link"/>
    <child link="elevation_link"/>
    <origin xyz="0 0 ${column_height}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="${pi/2}" effort="10.0" velocity="1.5708"/>
  </joint>

  <!-- Antenna Dish Link -->
  <link name="antenna_link">
    <visual>
      <geometry>
        <cylinder radius="${antenna_radius}" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${antenna_radius}" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="antenna_joint" type="fixed">
    <parent link="elevation_link"/>
    <child link="antenna_link"/>
    <origin xyz="${arm_length} 0 0" rpy="0 0 0"/>
  </joint>

  <!-- IMU Sensor Link -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="elevation_link"/>
    <child link="imu_link"/>
    <origin xyz="0.05 0 0.03" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo Plugins (Fortress) -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>azimuth_joint</joint_name>
      <joint_name>elevation_joint</joint_name>
    </plugin>

    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>azimuth_joint</joint_name>
      <topic>/model/antenna_tracker/joint/azimuth_joint/cmd_vel</topic>
    </plugin>

    <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
      <joint_name>elevation_joint</joint_name>
      <topic>/model/antenna_tracker/joint/elevation_joint/cmd_vel</topic>
    </plugin>

    <!-- Sensor systems -->
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-navsat-system" name="gz::sim::systems::NavSat"/>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/imu/raw</topic>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <!-- Fortress relies on the gz-sim-imu-system above processing this block -->
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <sensor name="gps_sensor" type="navsat">
      <always_on>true</always_on>
      <update_rate>1</update_rate>
      <topic>/gps/fix</topic>
    </sensor>
  </gazebo>

</robot>
